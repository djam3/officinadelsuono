{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product available in the shop",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the product"
        },
        "category": {
          "type": "string",
          "description": "The category of the product (e.g., Controller DJ, Casse Attive)"
        },
        "price": {
          "type": "number",
          "description": "The price of the product"
        },
        "image": {
          "type": "string",
          "description": "URL of the product image"
        },
        "badge": {
          "type": "string",
          "description": "Optional badge text (e.g., Best Seller)"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        },
        "averageRating": {
          "type": "number",
          "description": "The average rating of the product"
        },
        "reviewCount": {
          "type": "number",
          "description": "The number of reviews for the product"
        }
      },
      "required": ["name", "category", "price", "image"]
    },
    "Review": {
      "title": "Review",
      "description": "A user review for a product",
      "type": "object",
      "properties": {
        "productId": {
          "type": "string",
          "description": "The ID of the product being reviewed"
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who wrote the review"
        },
        "userName": {
          "type": "string",
          "description": "The name of the user who wrote the review"
        },
        "rating": {
          "type": "number",
          "description": "The star rating given by the user (1-5)"
        },
        "text": {
          "type": "string",
          "description": "The text content of the review"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        }
      },
      "required": ["productId", "userId", "userName", "rating", "text", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A user of the application, used for role-based access control",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "The user's role"
        }
      },
      "required": ["email", "role"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "profileImage": {
          "type": "string",
          "description": "URL of the owner's profile image"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp"
        }
      }
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": {
        "$ref": "#/entities/Product"
      },
      "description": "Collection of all products in the shop"
    },
    "/reviews/{reviewId}": {
      "schema": {
        "$ref": "#/entities/Review"
      },
      "description": "Collection of all reviews"
    },
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Collection of users for role management"
    },
    "/settings/{settingId}": {
      "schema": {
        "$ref": "#/entities/Settings"
      },
      "description": "Global settings collection"
    }
  }
}
