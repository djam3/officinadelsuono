rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((request.auth.token.email == "officinadelsuono99@gmail.com" && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function hasFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidProduct() {
      return hasFields(['name', 'category', 'price']) &&
        request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() < 100 &&
        request.resource.data.category is string && request.resource.data.category.size() > 0 && request.resource.data.category.size() < 50 &&
        request.resource.data.price is number && request.resource.data.price >= 0 &&
        (!('image' in request.resource.data) || (request.resource.data.image is string && request.resource.data.image.size() < 800000)) &&
        (!('images' in request.resource.data) || (request.resource.data.images is list && request.resource.data.images.size() <= 5)) &&
        (!('badge' in request.resource.data) || (request.resource.data.badge is string && request.resource.data.badge.size() < 50)) &&
        (!('specs' in request.resource.data) || request.resource.data.specs is map);
    }

    function isValidUser() {
      return hasFields(['email', 'role']) &&
        request.resource.data.email is string && request.resource.data.email.size() > 0 && request.resource.data.email.size() < 100 &&
        request.resource.data.role in ['admin', 'user'];
    }

    function isValidReview() {
      return hasFields(['productId', 'userId', 'userName', 'rating', 'text', 'createdAt']) &&
        request.resource.data.productId is string && request.resource.data.productId.size() > 0 && request.resource.data.productId.size() < 100 &&
        request.resource.data.userId is string && request.resource.data.userId == request.auth.uid &&
        request.resource.data.userName is string && request.resource.data.userName.size() > 0 && request.resource.data.userName.size() < 100 &&
        request.resource.data.rating is number && request.resource.data.rating >= 1 && request.resource.data.rating <= 5 &&
        request.resource.data.text is string && request.resource.data.text.size() > 0 && request.resource.data.text.size() <= 1000 &&
        request.resource.data.createdAt is string;
    }

    function isValidOrder() {
      return hasFields(['customerEmail', 'items', 'total', 'status', 'createdAt']) &&
        request.resource.data.customerEmail is string &&
        request.resource.data.customerEmail.size() > 3 &&
        request.resource.data.customerEmail.size() < 200 &&
        request.resource.data.customerEmail.matches('.*@.*\\..*') &&
        request.resource.data.items is list &&
        request.resource.data.items.size() > 0 &&
        request.resource.data.items.size() <= 50 &&
        request.resource.data.total is number &&
        request.resource.data.total >= 0 &&
        request.resource.data.total <= 100000 &&
        request.resource.data.status is string &&
        request.resource.data.status in ['nuovo', 'in_lavorazione', 'spedito', 'consegnato', 'annullato'] &&
        request.resource.data.createdAt is string &&
        (!('customerName' in request.resource.data) || (request.resource.data.customerName is string && request.resource.data.customerName.size() < 200)) &&
        (!('shippingAddress' in request.resource.data) || request.resource.data.shippingAddress is map) &&
        (!('notes' in request.resource.data) || (request.resource.data.notes is string && request.resource.data.notes.size() < 1000));
    }

    // ─── Products ────────────────────────────────────────────────────────────

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct();
      allow update: if isAdmin() && isValidProduct();
      allow delete: if isAdmin();
    }

    // ─── Reviews ─────────────────────────────────────────────────────────────

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidReview();
      allow update: if isAuthenticated() &&
        request.auth.uid == resource.data.userId &&
        isValidReview() &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.productId == resource.data.productId;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    // ─── Users ───────────────────────────────────────────────────────────────

    match /users/{userId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow create: if isAdmin() && isValidUser();
      allow update: if isAdmin() && isValidUser();
      allow delete: if isAdmin();
    }

    // ─── Settings ────────────────────────────────────────────────────────────
    // ai_config contiene la chiave API — solo admin può leggerla
    // Gli altri documenti (feature flags, site_content) restano pubblici

    match /settings/{settingId} {
      allow read: if settingId != 'ai_config' || isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Orders ──────────────────────────────────────────────────────────────
    // Chiunque può creare un ordine valido (checkout anonimo)
    // Admin può leggere/modificare/eliminare tutti gli ordini
    // Utente autenticato può leggere i propri ordini

    match /orders/{orderId} {
      allow create: if isValidOrder();
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // ─── Newsletter Subscribers ───────────────────────────────────────────────
    // Chiunque può iscriversi, solo admin può gestire

    match /newsletter_subscribers/{docId} {
      allow create: if request.resource.data.keys().hasAll(['email', 'subscribedAt', 'source'])
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 254;
      allow read, update, delete: if isAdmin();
    }

    // ─── Blog Posts ──────────────────────────────────────────────────────────

    match /blog_posts/{postId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ─── Chatbot Knowledge Base ───────────────────────────────────────────────

    match /chatbot_knowledge/{docId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ─── Chatbot Logs ─────────────────────────────────────────────────────────

    match /chatbot_logs/{logId} {
      allow read: if isAdmin();
      allow create: if true; // chatbot funziona anche anonimo
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ─── Discount Codes ──────────────────────────────────────────────────────

    match /discount_codes/{codeId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ─── Invoices ────────────────────────────────────────────────────────────

    match /invoices/{invoiceId} {
      allow read, write: if isAdmin();
    }

    // ─── AI Costs Tracker ─────────────────────────────────────────────────────

    match /ai_costs/{entryId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ─── Newsletter (legacy collection) ──────────────────────────────────────

    match /newsletter/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ─── Newsletter Subscriptions ─────────────────────────────────────────────

    match /newsletter_subscriptions/{subscriptionId} {
      allow read: if isAdmin();
      allow create: if hasFields(['email', 'privacyConsent', 'timestamp']) &&
        request.resource.data.email is string &&
        request.resource.data.email.size() > 3 &&
        request.resource.data.email.size() < 200 &&
        request.resource.data.email.matches('.*@.*\\..*') &&
        request.resource.data.privacyConsent is bool &&
        request.resource.data.privacyConsent == true &&
        request.resource.data.timestamp is string &&
        (!('marketingConsent' in request.resource.data) || request.resource.data.marketingConsent is bool) &&
        (!('source' in request.resource.data) || (request.resource.data.source is string && request.resource.data.source.size() < 100));
      allow update, delete: if isAdmin();
    }

    // ─── Social Media ─────────────────────────────────────────────────────────

    match /social_posts/{postId} {
      allow read, write: if isAdmin();
    }

    match /social_suggestions/{sugId} {
      allow read, write: if isAdmin();
    }

    // ─── Shipping Couriers ────────────────────────────────────────────────────

    match /shipping_couriers/{courierId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ─── Accounting ───────────────────────────────────────────────────────────

    match /accounting_entries/{entryId} {
      allow read, write: if isAdmin();
    }

    // ─── Error Logs ───────────────────────────────────────────────────────────

    match /error_logs/{errorId} {
      allow read: if isAdmin();
      allow create: if hasFields(['message', 'timestamp']) &&
        request.resource.data.message is string &&
        request.resource.data.message.size() > 0 &&
        request.resource.data.message.size() < 2000 &&
        (!('stack' in request.resource.data) || (request.resource.data.stack is string && request.resource.data.stack.size() < 5000)) &&
        (!('url' in request.resource.data) || (request.resource.data.url is string && request.resource.data.url.size() < 500)) &&
        (!('userAgent' in request.resource.data) || (request.resource.data.userAgent is string && request.resource.data.userAgent.size() < 500));
      allow update: if false;
      allow delete: if isAdmin();
    }

    // ─── AI Features Change Log ───────────────────────────────────────────────

    match /logs/ai_features_changes/entries/{entryId} {
      allow read, delete: if isAdmin();
      allow create: if isAdmin();
      allow update: if false;
    }
  }
}
